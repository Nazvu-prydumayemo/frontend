CourtCard {
    height: auto;
    margin: 0 0 1 0;
    padding: 1 2;
    border: round $accent;
    background: $panel;

    .court-card-name {
        text-style: bold;
        color: $text;
    }

    .court-card-location {
        color: $text-disabled;
    }

    .court-card-price {
        text-style: bold;
        color: $success;
    }

    .court-card-type {
        color: $text-disabled;
    }
}

CourtCard:hover {
    background: $surface;
}