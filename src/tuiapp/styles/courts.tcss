CourtCard {
    height: auto;
    margin: 0 0 1 0;
    padding: 1 2;
    border: round #444444;
    background: #2a2a2a;
}

CourtCard:hover {
    border: round $accent;
}

.court-card-body {
    height: auto;
    align: left top;
}

.court-card-name {
    text-style: bold;
    color: white;
}

.court-card-location {
    color: #888888;
}

.court-card-price {
    text-style: bold;
    color: $success;
}

.court-card-type {
    color: #888888;
}